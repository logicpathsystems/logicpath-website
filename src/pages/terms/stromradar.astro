</Layout>

<style>
    .legal-content h2 {
        color: var(--text-primary);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        font-size: 1.5rem;
    }
    
    .legal-content p, .legal-content ul {
        color: var(--text-secondary);
        margin-bottom: 1.25rem;
        font-size: 1.05rem;
        line-height: 1.7;
    }

    .legal-content ul {
        padding-left: 2rem;
        margin-bottom: 2rem;
    }

    .legal-content li {
        margin-bottom: 0.5rem;
    }
</style>
