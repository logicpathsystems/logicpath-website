---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Logicpath Systems - Transform Ideas Into Digital Solutions">

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-bg"></div>
        <div class="container hero-container reveal">
            <div class="hero-content">
                <div class="badge-style" style="margin-bottom: 2rem;">
                    <span>✨</span> Next-Gen Digital Solutions
                </div>
                <h1>We Build Apps<br>That <span class="gradient-text">People Love</span></h1>
                <p class="hero-subtitle">Transforming ideas into polished digital experiences. We are a professional Android & Web Development agency dedicated to building robust software.</p>
                <div class="cta-buttons">
                    <a href="#apps" class="btn btn-primary">View Our Work</a>
                    <a href="#contact" class="btn btn-secondary">Start Your Project</a>
                </div>
                
                <div class="trust-badges">
                    <div class="badge-item glass-card"><span>🚀</span> Trusted by 2,100+ Users</div>
                    <div class="badge-item glass-card"><span>⭐</span> 5.0 Average Rating</div>
                    <div class="badge-item glass-card"><span>📱</span> 2 Live Apps</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Apps Section -->
    <section id="apps" class="apps">
        <div class="container">
            <div class="section-header reveal">
                <h2>Our Featured <span class="gradient-text">Applications</span></h2>
                <p>Download our highly-rated mobile applications, designed for intuitive experiences and maximum productivity.</p>
            </div>
            
            <div class="apps-grid">
                <!-- App 1 -->
                <div class="app-card glass-card reveal">
                    <div class="app-image-container gradient-bg-1">
                        <img src="assets/images/calendar.png" alt="Marathi Calendar App" class="app-mockup">
                    </div>
                    <div class="app-content">
                        <span class="app-tag">Lifestyle</span>
                        <h3>Marathi Calendar 2026</h3>
                        <p>Your complete Marathi calendar companion with accurate panchang, festivals, and holidays. Beautiful wall calendar view with daily notes and reminders.</p>
                        <div class="app-metrics">
                            <div class="metric"><span class="val">2k+</span> <span class="lbl">Installs</span></div>
                            <div class="metric"><span class="val">⭐ 5.0</span> <span class="lbl">Rating</span></div>
                        </div>
                        <a href="https://play.google.com/store/apps/details?id=com.anjali.marathi_calendar" target="_blank" rel="noopener noreferrer" class="btn btn-primary w-full" style="width: 100%; margin-top: 1rem;">Get on Google Play</a>
                    </div>
                </div>

                <!-- App 2 -->
                <div class="app-card glass-card reveal" style="transition-delay: 0.2s;">
                    <div class="app-image-container gradient-bg-2">
                        <img src="assets/images/constitution.png" alt="Constitution App" class="app-mockup">
                    </div>
                    <div class="app-content">
                        <span class="app-tag">Education</span>
                        <h3>Constitution of India</h3>
                        <p>Master the Indian Constitution with all 395 Articles and 100+ Amendments. Features Interactive quizzes, flashcards, and daily notifications for easy learning.</p>
                        <div class="app-metrics">
                            <div class="metric"><span class="val">100+</span> <span class="lbl">Installs</span></div>
                            <div class="metric"><span class="val">⭐ 5.0</span> <span class="lbl">Rating</span></div>
                        </div>
                        <a href="https://play.google.com/store/apps/details?id=com.polityhub.constitution" target="_blank" rel="noopener noreferrer" class="btn btn-primary w-full" style="width: 100%; margin-top: 1rem;">Get on Google Play</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section id="stats" class="stats">
        <div class="container reveal">
            <div class="stats-wrapper glass-card">
                <div class="stat-item">
                    <div class="stat-icon">⬇️</div>
                    <div class="stat-number gradient-text">2,100+</div>
                    <div class="stat-label">Downloads</div>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <div class="stat-icon">📱</div>
                    <div class="stat-number gradient-text">2</div>
                    <div class="stat-label">Live Apps</div>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <div class="stat-icon">📅</div>
                    <div class="stat-number gradient-text">1+</div>
                    <div class="stat-label">Years Exp</div>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <div class="stat-icon">⭐</div>
                    <div class="stat-number gradient-text">5.0</div>
                    <div class="stat-label">Avg Rating</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
        <div class="container">
            <div class="section-header reveal">
                <h2>Our <span class="gradient-text">Services</span></h2>
                <p>Comprehensive digital solutions tailored to your business needs, built with modern technology stacks.</p>
            </div>
            
            <div class="services-grid">
                <div class="service-card glass-card reveal">
                    <div class="icon-wrapper">📱</div>
                    <h3>Android Dev</h3>
                    <p>Custom mobile applications built from concept to deployment on the Play Store.</p>
                </div>
                <div class="service-card glass-card reveal" style="transition-delay: 0.1s;">
                    <div class="icon-wrapper">🌐</div>
                    <h3>Web Dev</h3>
                    <p>Responsive, lightning-fast interfaces using modern frameworks like React and Astro.</p>
                </div>
                <div class="service-card glass-card reveal" style="transition-delay: 0.2s;">
                    <div class="icon-wrapper">🎨</div>
                    <h3>UI/UX Design</h3>
                    <p>Beautiful, intuitive user experiences crafted with precision and creativity.</p>
                </div>
                <div class="service-card glass-card reveal">
                    <div class="icon-wrapper">⚙️</div>
                    <h3>Backend Architecture</h3>
                    <p>Secure, massively scalable APIs and databases using top-tier cloud solutions.</p>
                </div>
                <div class="service-card glass-card reveal" style="transition-delay: 0.1s;">
                    <div class="icon-wrapper">🔧</div>
                    <h3>App Maintenance</h3>
                    <p>Relentless updates, optimization, and bug fixing to keep your app perfect.</p>
                </div>
                <div class="service-card glass-card reveal" style="transition-delay: 0.2s;">
                    <div class="icon-wrapper">📊</div>
                    <h3>Digital Marketing</h3>
                    <p>Data-driven App Store Optimization and user acquisition strategies.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <div class="about-flex reveal">
                <div class="about-text">
                    <div class="badge-style">Why Choose Us</div>
                    <h2>Excellence through <span class="gradient-text">Innovation</span></h2>
                    <p>We bring fresh ideas and modern solutions to every project. By utilizing cutting-edge tech and robust testing practices, we ensure your digital product stands out.</p>
                    <ul class="feature-list">
                        <li><span>✓</span> Ultra-Fast Delivery</li>
                        <li><span>✓</span> Scalable Architecture</li>
                        <li><span>✓</span> 24/7 Premium Support</li>
                    </ul>
                </div>
                <div class="about-image glass-card">
                    <div class="tech-grid">
                        <div class="tech-icon"><i class="devicon-flutter-plain colored"></i></div>
                        <div class="tech-icon"><i class="devicon-react-original colored"></i></div>
                        <div class="tech-icon"><i class="devicon-javascript-plain colored"></i></div>
                        <div class="tech-icon"><i class="devicon-firebase-plain colored"></i></div>
                        <div class="tech-icon"><i class="devicon-androidstudio-plain colored"></i></div>
                        <div class="tech-icon"><i class="devicon-git-plain colored"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="container">
            <div class="contact-grid">
                <div class="contact-info reveal">
                    <div class="badge-style">Get in Touch</div>
                    <h2>Let's Start Your <span class="gradient-text">Project</span></h2>
                    <p>Contact us today for a free consultation and let's craft something amazing together.</p>
                    
                    <div class="contact-methods">
                        <div class="contact-method">
                            <div class="contact-icon">📧</div>
                            <div>
                                <h4>Email Us</h4>
                                <a href="mailto:contact@logicpathsystems.com">contact@logicpathsystems.com</a>
                            </div>
                        </div>
                        <div class="contact-method">
                            <div class="contact-icon">📞</div>
                            <div>
                                <h4>Call Us</h4>
                                <span>+91 9422067401</span>
                            </div>
                        </div>
                        <div class="contact-method">
                            <div class="contact-icon">📍</div>
                            <div>
                                <h4>Visit Us</h4>
                                <span>534/4/54, Shanti Nagar, Barshi<br>Maharashtra - 413401</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="contact-form-wrapper glass-card reveal" style="transition-delay: 0.2s;">
                    <form id="contactForm" action="https://formspree.io/f/mqelryww" method="POST" class="modern-form">
                        <div class="form-group">
                            <label for="name">Name</label>
                            <input type="text" id="name" name="name" required placeholder="Your full name">
                        </div>
                        <div class="form-group">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" required placeholder="name@company.com">
                        </div>
                        <div class="form-group">
                            <label for="service">Service Needed</label>
                            <select id="service" name="service">
                                <option value="android">Android App Development</option>
                                <option value="web">Web Development</option>
                                <option value="ui-ux">UI/UX Design</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="message">Project Details</label>
                            <textarea id="message" name="message" required placeholder="Tell us about your project..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary" style="width: 100%;">Send Message 🚀</button>
                        <div id="formMessage" class="form-message"></div>
                    </form>
                </div>
            </div>
        </div>
    </section>

</Layout>

<style>
    /* Hero Section */
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        position: relative;
        padding-top: 100px; /* Offset for header */
        overflow: hidden;
    }
    
    .hero-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: radial-gradient(circle at 20% 30%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
                    radial-gradient(circle at 80% 70%, rgba(34, 211, 238, 0.15) 0%, transparent 50%);
        z-index: 0;
    }
    
    .hero-container {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    
    .hero-content {
        max-width: 900px;
        margin: 0 auto;
    }
    
    .hero h1 {
        margin-bottom: 2rem;
    }
    
    .hero-subtitle {
        font-size: clamp(1.125rem, 2.5vw, 1.35rem);
        color: var(--text-secondary);
        max-width: 700px;
        margin: 0 auto 3rem;
    }
    
    .cta-buttons {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 4rem;
    }

    .trust-badges {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .trust-badges .badge-item {
        padding: 0.75rem 1.5rem;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 500;
        font-size: 0.95rem;
    }

    /* Apps Section */
    .apps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 2.5rem;
    }
    
    .app-card {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    }
    
    .app-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }
    
    .app-image-container {
        height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }
    
    .gradient-bg-1 { background: linear-gradient(135deg, rgba(99, 102, 241, 0.2) 0%, rgba(34, 211, 238, 0.2) 100%); }
    .gradient-bg-2 { background: linear-gradient(135deg, rgba(236, 72, 153, 0.2) 0%, rgba(139, 92, 246, 0.2) 100%); }
    
    .app-mockup {
        height: 100%;
        object-fit: contain;
        filter: drop-shadow(0 20px 30px rgba(0,0,0,0.3));
        transition: transform 0.4s ease;
    }
    
    .app-card:hover .app-mockup {
        transform: scale(1.05) translateY(-5px);
    }
    
    .app-content {
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }
    
    .app-tag {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--accent-secondary);
        margin-bottom: 1rem;
    }
    
    .app-metrics {
        display: flex;
        gap: 1.5rem;
        margin-block: auto 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    
    .metric {
        display: flex;
        flex-direction: column;
    }
    
    .metric .val { font-weight: 700; font-size: 1.25rem; color: var(--text-primary); }
    .metric .lbl { font-size: 0.85rem; color: var(--text-secondary); }

    /* Stats Section */
    .stats-wrapper {
        display: flex;
        justify-content: space-around;
        align-items: center;
        padding: 3rem;
        flex-wrap: wrap;
        gap: 2rem;
    }
    
    .stat-item {
        text-align: center;
        flex: 1;
        min-width: 150px;
    }
    
    .stat-icon { font-size: 2.5rem; margin-bottom: 1rem; }
    .stat-number { font-size: clamp(2.5rem, 4vw, 3.5rem); font-family: 'Outfit'; font-weight: 800; line-height: 1; margin-bottom: 0.5rem; }
    .stat-label { font-size: 1.1rem; color: var(--text-secondary); font-weight: 500; }
    
    .stat-divider {
        width: 1px;
        height: 80px;
        background: rgba(255,255,255,0.1);
    }

    /* Services Section */
    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }
    
    .service-card {
        padding: 2.5rem;
        transition: transform 0.3s ease, background 0.3s ease;
    }
    
    .service-card:hover {
        transform: translateY(-5px);
        background: rgba(30, 41, 59, 0.9);
        border-color: rgba(99, 102, 241, 0.3);
    }
    
    .icon-wrapper {
        width: 60px; height: 60px;
        border-radius: 14px;
        background: rgba(99, 102, 241, 0.1);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.75rem;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(99, 102, 241, 0.2);
    }
    
    /* About Section */
    .about-flex {
        display: flex;
        align-items: center;
        gap: 4rem;
    }
    
    .about-text { flex: 1; }
    .about-text h2 { margin-block: 1rem 1.5rem; }
    
    .feature-list {
        list-style: none;
        margin-top: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    
    .feature-list li {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 1.1rem;
        color: var(--text-primary);
    }
    
    .feature-list li span {
        color: var(--accent-secondary);
        font-weight: 800;
    }
    
    .about-image {
        flex: 1;
        padding: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at center, rgba(99,102,241,0.1), transparent);
    }
    
    .tech-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }
    
    .tech-icon {
        font-size: 3.5rem;
        filter: grayscale(1) opacity(0.7);
        transition: all 0.3s ease;
        text-align: center;
    }
    
    .tech-icon:hover {
        filter: grayscale(0) opacity(1);
        transform: scale(1.1);
    }

    /* Contact Section */
    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 4rem;
        align-items: start;
    }
    
    .contact-info h2 { margin-block: 1rem; }
    .contact-info p { margin-bottom: 3rem; font-size: 1.125rem; }
    
    .contact-methods {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }
    
    .contact-method {
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
    }
    
    .contact-method .contact-icon {
        width: 50px; height: 50px;
        border-radius: 50%;
        background: rgba(34, 211, 238, 0.1);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
    }
    
    .contact-method h4 { margin-bottom: 0.25rem; font-size: 1.1rem; }
    .contact-method a, .contact-method span { color: var(--text-secondary); text-decoration: none; }
    .contact-method a:hover { color: var(--accent-secondary); }
    
    .contact-form-wrapper { padding: 3rem; }
    
    .modern-form .form-group { margin-bottom: 1.5rem; }
    .modern-form label {
        display: block; margin-bottom: 0.5rem;
        font-size: 0.9rem; font-weight: 500; color: var(--text-secondary);
    }
    .modern-form input, .modern-form select, .modern-form textarea {
        width: 100%;
        padding: 1rem;
        background: rgba(15, 23, 42, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        color: var(--text-primary);
        font-family: inherit;
        font-size: 1rem;
        transition: all 0.3s ease;
    }
    .modern-form input:focus, .modern-form select:focus, .modern-form textarea:focus {
        outline: none;
        border-color: var(--accent-primary);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
    }
    .modern-form textarea { min-height: 120px; resize: vertical; }

    /* Responsive Overrides */
    @media (max-width: 992px) {
        .about-flex { flex-direction: column; }
        .contact-grid { grid-template-columns: 1fr; }
        .stat-divider { display: none; }
    }

    @media (max-width: 768px) {
        .hero { padding-top: 120px; }
        .cta-buttons { flex-direction: column; width: 100%; }
        .cta-buttons .btn { width: 100%; }
        .trust-badges { flex-direction: column; width: 100%; align-items: stretch;}
        .app-image-container { height: 200px; }
        .contact-form-wrapper { padding: 2rem 1.5rem; }
    }
</style>

<script>
    // Form handling
    const form = document.getElementById('contactForm');
    const msgDiv = document.getElementById('formMessage');
    
    if (form && msgDiv) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
            if(btn) {
                const originalText = btn.innerHTML;
                btn.innerHTML = 'Sending... ⏳';
                btn.disabled = true;
                
                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form as HTMLFormElement),
                        headers: { 'Accept': 'application/json' }
                    });
                    
                    if (response.ok) {
                        msgDiv.innerHTML = '<div style="color:var(--accent-secondary); margin-top:1rem; padding:1rem; background:rgba(34,211,238,0.1); border-radius:8px;">Message sent successfully! We will get back to you soon.</div>';
                        (form as HTMLFormElement).reset();
                    } else {
                        throw new Error('Form submission failed');
                    }
                } catch (error) {
                    msgDiv.innerHTML = '<div style="color:#ef4444; margin-top:1rem; padding:1rem; background:rgba(239,68,68,0.1); border-radius:8px;">Oops! There was a problem. Please try again later.</div>';
                } finally {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    setTimeout(() => { msgDiv.innerHTML = ''; }, 5000);
                }
            }
        });
    }
</script>
